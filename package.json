    "k1:prompt:joint": "k1 prompt joint",
    "k1:voice": "k1 voice",
    "k1:voice:joint": "k1 voice joint",
    "test": "jest .",
    "start": "node scripts/main",
    "demo": "node scripts/demo",
    "control": "node scripts/control",
    "main": "node scripts/main",
    "prompt": "node scripts/prompt",
    "repl": "node scripts/repl",
    "voice": "node scripts/voice",
    "lint": "npm run prettier && eslint . --fix",
    "lint:ci": "eslint . && npm run prettier:ci",
    "prettier": "prettier \"**/*.{js,json,md,yml,yaml}\" --write --log-level error",
    "prettier:ci": "prettier \"**/*.{js,json,md,yml,yaml}\" --check"
