{
  "name": "robosen-js",
  "version": "0.9.1",
  "description": "RobosenJS is a Node.js library to control Robosen robots.",
  "main": "index.js",
  "bin": {
    "k1": "bin/k1.js"
  },
  "files": [
    "bin",
    "src"
  ],
  "scripts": {
    "k1": "k1",
    "k1:repl": "k1 repl",
    "k1:control": "k1 control",
